PORT=3006

# Nominatim (OpenStreetMap): set a real app identifier — https://operations.osmfoundation.org/policies/nominatim/
NOMINATIM_USER_AGENT=dispatch-solar-mapper/1.0 (your-email@example.com)
# Optional: ms between geocode calls (default 1100)
# NOMINATIM_GAP_MS=1100

# NREL key for solar_resource + PVWatts (DEMO_KEY works for light testing)
NREL_API_KEY=DEMO_KEY
